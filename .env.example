# Copy to .env and adjust

# Postgres (used by docker-compose; the app reads DATABASE_URL)
POSTGRES_USER=pricehunter
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=pricehunter

# Connection string the app uses (matches the docker-compose service name "db")
DATABASE_URL=postgresql+asyncpg://pricehunter:change_me_in_prod@db:5432/pricehunter

# Where uploaded receipts and image cache live, mounted into the container
DATA_DIR=/app/data

# App
APP_HOST=0.0.0.0
APP_PORT=3016
APP_ENV=development

# Telegram bot (filled in when the bot is configured)
TELEGRAM_BOT_TOKEN=
TELEGRAM_HOME_CHAT_ID=

# Open Food Facts client (no auth needed)
OFF_API_URL=https://world.openfoodfacts.org

# Admin token for /api/admin/seed (X-Seed-Token header).  Generate a fresh
# one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=
